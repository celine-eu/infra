image:
  tag: {{ .Environment.Values.nudging.image_tag | default "latest" | quote }}

oidc:
  service:
    clientSecret: {{ .Environment.Values | dig "nudging" "client_secret" "svc-nudging" | quote }}

{{- with .Environment.Values | dig "nudging" "resources" nil }}
resources:
  {{- toYaml . | nindent 2 }}
{{- end }}
