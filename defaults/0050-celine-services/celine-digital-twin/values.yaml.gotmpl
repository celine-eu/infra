image:
  tag: {{ .Environment.Values.digital_twin.image_tag | default "latest" | quote }}

logLevel: "DEBUG"

oidc:
  service:
    clientSecret: {{ .Environment.Values | dig "digital_twin" "client_secret" "svc-digital-twin" | quote }}

{{- with .Environment.Values | dig "digital_twin" "resources" nil }}
resources:
  {{- toYaml . | nindent 2 }}
{{- end }}
