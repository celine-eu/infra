image:
  tag: {{ .Environment.Values.ai_assistant.image_tag | default "latest" | quote }}

oidc:
  service:
    # skip client ID / secrets
    passthrough: true
    clientId: ""
    audience: "oauth2_proxy"
    clientSecret: ""

  includeClientIdAsAudience: false
  allowedAudiences: ""

extraEnv:
  - name: QDRANT_URL
    value: http://qdrant:6333
  - name: OPENAI_API_KEY
    value: {{ .Environment.Values.ai_assistant.openai_api_key | quote }}
  - name: TRAINING_MATERIALS_REPO_URL
    value: {{ .Environment.Values.ai_assistant.training_material_url | quote }}
  - name: TRAINING_MATERIALS_PATH
    value: "/tmp/training-material"
  - name: MANIFEST_PATH
    value: "/tmp/manifest.json"

{{- with .Environment.Values | dig "ai_assistant" "resources" nil }}
resources:
  {{- toYaml . | nindent 2 }}
{{- end }}