image:
  tag: {{ .Environment.Values.dataset_api.image_tag | default "latest" | quote }}

oidc:
  service:
    clientSecret: {{ .Environment.Values | dig "dataset_api" "client_secret" "svc-dataset-api" | quote }}

{{- with .Environment.Values | dig "dataset_api" "resources" nil }}
resources:
  {{- toYaml . | nindent 2 }}
{{- end }}
